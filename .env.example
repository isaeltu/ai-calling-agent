# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Optional overrides:
# GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
# GEMINI_VOICE=Puck

# Twilio Configuration (per-restaurant phone numbers now live in restaurants.json)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Server Configuration
# Local dev: your ngrok URL (e.g. https://your-ngrok-url.ngrok-free.dev)
# Production (Railway, etc.): your deployed public URL
PUBLIC_BASE_URL=https://your-public-url
PORT=8000

# Webhook secret used to authenticate with the restaurant's order system
# (Authorization: Bearer header in submit_order). Used as a fallback for any
# restaurants.json entry that does not set its own order_webhook_api_key.
ORDER_WEBHOOK_API_KEY=your_restaurant_order_webhook_api_key
