# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Optional overrides:
# GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
# GEMINI_VOICE=Puck

# SignalWire Configuration (per-restaurant phone numbers now live in restaurants.json)
SIGNALWIRE_PROJECT_ID=your_signalwire_project_id
SIGNALWIRE_TOKEN=your_signalwire_api_token
SIGNALWIRE_SPACE_URL=your-space.signalwire.com

# Server Configuration
# Local dev: your ngrok URL (e.g. https://your-ngrok-url.ngrok-free.dev)
# Production (Railway, etc.): your deployed public URL
PUBLIC_BASE_URL=https://your-public-url
PORT=8000

# Webhook secrets used to authenticate with each restaurant's order system
# (Authorization: Bearer header in submit_order). Each restaurant entry in
# restaurants.json names its own env var via "order_webhook_api_key_env"; a
# restaurant with no order_webhook_api_key_env falls back to ORDER_WEBHOOK_API_KEY.
ORDER_WEBHOOK_API_KEY=your_default_restaurant_order_webhook_api_key
# Example for one specific restaurant (name matches order_webhook_api_key_env):
# ORDER_WEBHOOK_API_KEY_CHICHARRON=voice_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RestoPOS Supabase project, used to fetch each restaurant's live menu
# (rpc/voice_get_menu) before talking to the customer. Same project the
# order webhook above points to.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
