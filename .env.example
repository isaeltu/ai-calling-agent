# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Optional overrides:
# GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview
# GEMINI_VOICE=Puck
# GEMINI_MAX_OUTPUT_TOKENS=240
# GEMINI_THINKING_LEVEL=MINIMAL
# GEMINI_ENABLE_TRANSCRIPTIONS=false
# GEMINI_MANUAL_VAD=true
# GEMINI_MANUAL_VAD_SILENCE_MS=320
# GEMINI_MANUAL_VAD_PREFIX_MS=160
# GEMINI_MANUAL_VAD_START_MS=80
# GEMINI_END_OF_SPEECH_SILENCE_MS=100
# GEMINI_START_OF_SPEECH_PADDING_MS=20
# SILENCE_GATE_RMS_THRESHOLD=450
# SILENCE_GATE_HANGOVER_MS=300

# Twilio Configuration (per-restaurant phone numbers now live in restaurants.json)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Server Configuration
# Local dev: your ngrok URL (e.g. https://your-ngrok-url.ngrok-free.dev)
# Production (Railway, etc.): your deployed public URL
PUBLIC_BASE_URL=https://your-public-url
PORT=8000

# Webhook secrets used to authenticate with each restaurant's order system
# (Authorization: Bearer header in submit_order). Each restaurant entry in
# restaurants.json names its own env var via "order_webhook_api_key_env"; a
# restaurant with no order_webhook_api_key_env falls back to ORDER_WEBHOOK_API_KEY.
ORDER_WEBHOOK_API_KEY=your_default_restaurant_order_webhook_api_key
# Example for one specific restaurant (name matches order_webhook_api_key_env):
# ORDER_WEBHOOK_API_KEY_CHICHARRON=voice_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RestoPOS Supabase project, used to fetch each restaurant's live menu
# (rpc/voice_get_menu) before talking to the customer. Same project the
# order webhook above points to.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Low-latency menu/order settings. The server preloads and caches menu data
# so Gemini receives real products/prices without waiting on Supabase per turn.
# MENU_CACHE_TTL_SECONDS=300
# MENU_STALE_TTL_SECONDS=3600
# MENU_FETCH_TIMEOUT_SECONDS=2.5
# MENU_MAX_ITEMS_IN_PROMPT=120
# ORDER_WEBHOOK_TIMEOUT_SECONDS=3.0
# CALL_LOG_TIMEOUT_SECONDS=2.0
